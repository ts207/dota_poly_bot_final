# Required for Dota GetTopLiveGame
STEAM_API_KEY=your_steam_web_api_key

# Recommended: let the bot find active Polymarket Dota match-winner markets and CLOB token IDs.
AUTO_DISCOVER_POLYMARKET=true
# Keep false by default. Setting true allows market selection without confirmed Dota live-game alignment.
ALLOW_UNCONFIRMED_POLYMARKET_MAPPING=false

# Optional manual overrides. Leave blank/placeholder when AUTO_DISCOVER_POLYMARKET=true.
MARKET_ID=
RADIANT_TOKEN_ID=
DIRE_TOKEN_ID=

# Best Dota matching options. Prefer server ID or exact team pair.
TARGET_SERVER_STEAM_ID=
TARGET_RADIANT_TEAM=
TARGET_DIRE_TEAM=
TARGET_MATCH=

# Collection
DATABASE_PATH=./data/dota_poly_collection.sqlite
DOTA_POLL_INTERVAL=1.0
DOTA_PARTNERS=0,1,2,3
# (Optional) OpenDota API key for historical data gathering
OPENDOTA_API_KEY=your_opendota_api_key
STRATZ_API_KEY=your_stratz_api_key

# Polymarket book validation
PM_SNAPSHOT_INTERVAL_S=120
PM_BOOK_VALIDATION_TOLERANCE=0.01

# Dry-run order behavior
ORDER_PRICE_IMPROVE=0.01
ORDER_CANCEL_AFTER_S=2.0

# Signal thresholds/weights
SIGNAL_MAX_SPREAD=0.04
SIGNAL_MAX_MID_DISAGREEMENT=0.08
SIGNAL_MIN_DEPTH=50
SIGNAL_MIN_EDGE=0.03
SIGNAL_LEAD_60S_WEIGHT=0.000012
SIGNAL_LEAD_30S_WEIGHT=0.000006
SIGNAL_LEAD_10S_WEIGHT=0.000003
SIGNAL_SCORE_60S_WEIGHT=0.010
SIGNAL_SCORE_30S_WEIGHT=0.005
SIGNAL_MAX_EXPECTED_MOVE=0.25

# Risk limits
RISK_MAX_POSITION_PER_MATCH=100
RISK_MAX_ORDER_SIZE=20
RISK_MAX_DOTA_TICK_AGE_MS=1500
RISK_MAX_BOOK_AGE_MS=800
RISK_MAX_SPREAD=0.04
RISK_MAX_COMBINED_DISAGREEMENT=0.08

# --- Tiny live-probe mode (OFF by default) ---
# This is for measuring real order acknowledgements, cancels, and fills with tiny size.
# Keep disabled unless you have manually verified MARKET_ID/RADIANT_TOKEN_ID/DIRE_TOKEN_ID
# and TARGET_SERVER_STEAM_ID for the exact live Dota match.
ENABLE_LIVE_TRADING=false
LIVE_PROBE_ONLY=true
LIVE_MAX_ORDER_SIZE=1.00
LIVE_MAX_POSITION_PER_MATCH=5.00
LIVE_MAX_ORDERS_PER_MATCH=5
LIVE_CANCEL_AFTER_S=1.5

# Polymarket CLOB credentials for live probe mode.
POLY_HOST=https://clob.polymarket.com
POLY_CHAIN_ID=137
POLY_PRIVATE_KEY=
POLY_FUNDER=
# Some proxy wallets require a signature type. Leave blank unless your setup needs it.
POLY_SIGNATURE_TYPE=

# Live-probe fill logging
# Comma-separated seconds after detected fill to snapshot target-token book.
LIVE_FILL_SNAPSHOT_OFFSETS_S=0,5,15,30,60

# Strategy trigger controls
# For first live probes, keep only the strongest latency/underreaction triggers enabled.
ENABLED_TRIGGERS=FIGHT_GAP,LEAD_FLIP_GAP,MARKET_CONFIRM,STRUCTURE_GAP,STRUCTURE_EVENT
BLOCKED_TRIGGERS=SLOW_BLEED,OVERREACTION,FIGHT_EVENT,LEAD_FLIP_EVENT
# Format: TRIGGER:min-max minutes, comma-separated.
TRIGGER_MINUTE_WINDOWS=FIGHT_GAP:8-45,LEAD_FLIP_GAP:12-40,MARKET_CONFIRM:10-45,STRUCTURE_GAP:10-45,SLOW_BLEED:15-35
# Optional per-trigger edge floors. The effective edge floor is max(SIGNAL_MIN_EDGE, trigger floor).
TRIGGER_EDGE_FLOORS=FIGHT_GAP:0.03,LEAD_FLIP_GAP:0.03,MARKET_CONFIRM:0.03,STRUCTURE_GAP:0.03,SLOW_BLEED:0.045,STRUCTURE_EVENT:0.045
# Log throttled signal/execution rejection reasons to signal_rejections.
LOG_SIGNAL_REJECTIONS=true

# Auto-ID discovery output
# When AUTO_DISCOVER_POLYMARKET=true, the bot writes the discovered target mapping here.
WRITE_DISCOVERED_TARGET_ENV=true
DISCOVERED_TARGET_ENV_PATH=./data/last_discovered_target.env

# Optional: allow live-probe mode to use automatically discovered IDs.
# Still requires confirmed Dota server alignment and ALLOW_UNCONFIRMED_POLYMARKET_MAPPING=false.
# Safer path: run dry discovery first, inspect data/last_discovered_target.env, then live.
ALLOW_LIVE_AUTO_DISCOVERY=false
# Extremely risky: allows the bot to select any currently visible Dota/Polymarket match if no target is set.
ALLOW_LIVE_ANY_DISCOVERED_MATCH=false
