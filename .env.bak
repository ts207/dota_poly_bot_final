# Required for Dota GetTopLiveGame
STEAM_API_KEY=5715C5A721591E946229DDA658FD1AFD

# Recommended: let the bot find active Polymarket Dota match-winner markets and CLOB token IDs.
AUTO_DISCOVER_POLYMARKET=true
# Keep false by default. Setting true allows market selection without confirmed Dota live-game alignment.
ALLOW_UNCONFIRMED_POLYMARKET_MAPPING=true

# Optional manual overrides. Leave blank/placeholder when AUTO_DISCOVER_POLYMARKET=true.
MARKET_ID=
RADIANT_TOKEN_ID=
DIRE_TOKEN_ID=

# Best Dota matching options. Prefer server ID or exact team pair.
TARGET_SERVER_STEAM_ID=...
TARGET_RADIANT_TEAM=Power Rangers
TARGET_DIRE_TEAM=Modus
TARGET_MATCH=

# Collection
DATABASE_PATH=./data/dota_poly_collection.sqlite
DOTA_POLL_INTERVAL=0.5
DOTA_PARTNERS=0,1,2,3
STRATZ_API_KEY=
# Polymarket book validation
PM_SNAPSHOT_INTERVAL_S=120
PM_BOOK_VALIDATION_TOLERANCE=0.01

# Dry-run order behavior
ORDER_PRICE_IMPROVE=0.01
ORDER_CANCEL_AFTER_S=2.0

# Signal thresholds/weights
SIGNAL_MAX_SPREAD=0.15
SIGNAL_MAX_MID_DISAGREEMENT=0.12
SIGNAL_MIN_DEPTH=50
SIGNAL_MIN_EDGE=0.03
SIGNAL_MIN_EXPECTED_MOVE=0.015
SIGNAL_LEAD_60S_WEIGHT=0.000036
SIGNAL_LEAD_30S_WEIGHT=0.000018
SIGNAL_LEAD_10S_WEIGHT=0.000009
SIGNAL_SCORE_60S_WEIGHT=0.035
SIGNAL_SCORE_30S_WEIGHT=0.015
SIGNAL_MAX_EXPECTED_MOVE=0.25

# Risk limits
RISK_MAX_POSITION_PER_MATCH=250
RISK_MAX_ORDER_SIZE=50
RISK_MAX_DOTA_TICK_AGE_MS=300000
RISK_MAX_BOOK_AGE_MS=2500
RISK_MAX_SPREAD=0.15
RISK_MAX_COMBINED_DISAGREEMENT=0.12
RISK_MIN_EXIT_DEPTH=25.0
